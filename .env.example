# auth-gateway configuration (copy to .env and adjust)

# Full URLs of the two oauth2-proxy backends (required).
BACKEND_PRIMARY=http://localhost:4180
BACKEND_SECONDARY=http://localhost:4181

# Address the gateway listens on (default :8080).
LISTEN_ADDR=:8080

# Name of the routing cookie (default auth_mode).
COOKIE_NAME=auth_mode
